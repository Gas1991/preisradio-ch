# Copier ce fichier en .env et renseigner les valeurs

SECRET_KEY=changez-moi-en-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — origines autorisées (séparées par virgule)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://priesradio.ch

# MongoDB — Stores suisses
MONGODB_DIGITEC_URI=mongodb+srv://...
MONGODB_DIGITEC_DB=Digitec
MONGODB_DIGITEC_COLLECTION=DB

MONGODB_INTERDISCOUNT_URI=mongodb+srv://...
MONGODB_INTERDISCOUNT_DB=Interdiscount
MONGODB_INTERDISCOUNT_COLLECTION=DB

MONGODB_BRACK_URI=mongodb+srv://...
MONGODB_BRACK_DB=Brack
MONGODB_BRACK_COLLECTION=DB

# Email
DEFAULT_FROM_EMAIL=noreply@priesradio.ch
